{
  "name": "ecommerce-contract",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Canonical API contract authored in TypeSpec; emits OpenAPI 3.1 (REST) and JSON Schema (shared payloads).",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsp compile .",
    "watch": "tsp compile . --watch"
  },
  "devDependencies": {
    "@typespec/compiler": "^1.13.0",
    "@typespec/http": "^1.13.0",
    "@typespec/openapi3": "^1.13.0",
    "@typespec/json-schema": "^1.13.0"
  }
}
