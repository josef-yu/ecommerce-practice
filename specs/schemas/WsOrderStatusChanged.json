{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "WsOrderStatusChanged.json",
    "type": "object",
    "properties": {
        "type": {
            "type": "string",
            "const": "ORDER_STATUS_CHANGED"
        },
        "payload": {
            "type": "object",
            "properties": {
                "order_id": {
                    "type": "string"
                },
                "status": {
                    "type": "string"
                },
                "updated_at": {
                    "type": "string",
                    "format": "date-time"
                }
            },
            "required": [
                "order_id",
                "status",
                "updated_at"
            ]
        }
    },
    "required": [
        "type",
        "payload"
    ],
    "allOf": [
        {
            "$ref": "WsServerEvent.json"
        }
    ]
}