{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "Product.json",
    "type": "object",
    "properties": {
        "id": {
            "type": "string"
        },
        "name": {
            "type": "string"
        },
        "description": {
            "type": "string"
        },
        "price": {
            "type": "integer",
            "minimum": -2147483648,
            "maximum": 2147483647,
            "description": "Cents."
        },
        "stock_quantity": {
            "type": "integer",
            "minimum": -2147483648,
            "maximum": 2147483647
        },
        "merchant_id": {
            "type": "string"
        },
        "status": {
            "$ref": "ProductStatus.json"
        },
        "created_at": {
            "type": "string",
            "format": "date-time"
        }
    },
    "required": [
        "id",
        "name",
        "description",
        "price",
        "stock_quantity",
        "merchant_id",
        "status",
        "created_at"
    ]
}