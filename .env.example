# ---------------------------------------------------------------
# Shared infrastructure — copy this file to .env and fill in.
# These values are read by docker-compose.yml and exported to
# all backend / fullstack processes by the root Makefile.
# ---------------------------------------------------------------

# --- Postgres ---
POSTGRES_DB=ecommerce
POSTGRES_USER=ecommerce
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PORT=6379

# --- Mailpit (local SMTP trap) ---
SMTP_PORT=1025
MAILPIT_UI_PORT=8025

# --- MinIO (local object storage) ---
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme

# --- Auth ---
# Must be a long random string in any real deployment.
JWT_SECRET=changeme-replace-with-64-random-chars

# --- Payment provider (use test/sandbox keys) ---
PAYMENT_SECRET_KEY=sk_test_replace_me
PAYMENT_PUBLISHABLE_KEY=pk_test_replace_me
PAYMENT_WEBHOOK_SECRET=whsec_replace_me

# --- Logistics (carrier webhook HMAC) ---
CARRIER_WEBHOOK_SECRET=changeme

# --- Google OAuth ---
GOOGLE_CLIENT_ID=replace_me.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=replace_me
